{
  "name": "tabx-chrome-extension",
  "version": "0.1.0",
  "description": "TabX - Relevance-based tab lifecycle manager with agent handoff",
  "private": true,
  "scripts": {
    "build": "bun run build:clean && bun run build:bundle",
    "build:clean": "rm -rf dist",
    "build:bundle": "bun run scripts/build.ts",
    "dev": "bun run scripts/build.ts --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/bun": "^1.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
